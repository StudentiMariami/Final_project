<resources>
    <!--
        App theme — extends Material3 DayNight theme.
        DayNight automatically switches between light and dark mode.
        NoActionBar means we use our own Toolbar (not the default system ActionBar).
    -->
    <style name="Theme.AFinal" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color (Toolbar, FAB, buttons) -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary accent color -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
    </style>
</resources>
